MDScreen:
    MDBoxLayout:
        orientation: "vertical"

        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: 70
            padding: 16, 8, 16, 8

            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            
            BoxLayout:
                orientation: "vertical"
                size: root.width, root.height

                MDLabel:
                    text: "IP Address"
                    role: "medium"
                MDLabel:
                    text: "192.168.1.0"
                    role: "medium"
                    theme_text_color: "Custom"
                    text_color: "green"
                    

            MDLabel:
                text: "ALT Iddrives"
                halign: "center"
                font_style: "Headline"
                bold: True
                

            BoxLayout:
                orientation: "vertical"
                size: root.width, root.height

                MDLabel:
                    text: "Status"
                    role: "medium"
                    halign: "right"

                MDLabel:
                    text: "Online"
                    role: "medium"
                    halign: "right"
                    theme_text_color: "Custom"
                    text_color: "green"


        MDScreenManager:
            # md_bg_color: app.theme_cls.primaryColor
            id: screen_manager

            # PrepareResult:
            #     name: "prepareresult"
            Home:
                name: "home"
            EmployeeID:
                name: "employeeid"
            Authing:
                name: "authing"
            Breathing:
                name: "breathing"
            TestResult:
                name: "testresult"
            ShowError:
                name: "showerror"
#:import get_color_from_hex kivy.utils.get_color_from_hex

<TestResult>:
    md_bg_color: get_color_from_hex("#e8fffeff")

    MDBoxLayout:
        orientation: "horizontal"
        spacing: "20dp"
        padding: "20dp"
        size: root.width, root.height

        # Left Column: Snapshot Image
        MDBoxLayout:
            orientation: "vertical"
            size_hint_x: .4
            spacing: "12dp"

            Label:
                text: "Snapshot"
                halign: "center"
                font_name: "Sarabun"
                font_size: 52
                color: (0, 0, 0, 1)
                size_hint_y: None
                height: "64dp"

            MDCard:
                size_hint: 1, 1
                style: "outlined"
                line_color: 0, 0, 0, 1
                line_width: 2
                padding: "8dp"

                FloatLayout:
                    Image:
                        id: snapshot_image
                        source: root.snapshot_path if root.snapshot_path else ""
                        fit_mode: "contain"
                        pos_hint: {'center_x': .5, 'center_y': .5}
                        opacity: 1 if root.snapshot_path else 0

                    MDLabel:
                        text: "No Image"
                        halign: "center"
                        valign: "center"
                        theme_text_color: "Hint"
                        pos_hint: {'center_x': .5, 'center_y': .5}
                        opacity: 1 if not root.snapshot_path else 0

        # Right Column: Result + Done button
        MDBoxLayout:
            orientation: "vertical"
            size_hint_x: .6
            spacing: "16dp"

            Widget:
                size_hint_y: 1

            MDIconButton:
                icon: 'checkbox-marked-circle-outline'
                style: "filled"
                theme_font_size: "Custom"
                font_size: "130sp"
                radius: [self.height / 2, ]
                size_hint: None, None
                size: "170dp", "170dp"
                pos_hint: {'center_x': .5}
                theme_bg_color: "Custom"
                md_bg_color: get_color_from_hex("#d4fdd6ff")
                theme_icon_color: "Custom"
                icon_color: get_color_from_hex("#008000ff")

            MDCard:
                style: "elevated"
                padding: "24dp"
                spacing: "16dp"
                size_hint: 1, None
                height: "390dp"
                pos_hint: {'center_x': .5}
                orientation: "vertical"

                Label:
                    text: 'ผลการตรวจ | Test Result'
                    halign: "center"
                    font_name: "Sarabun"
                    font_size: 56
                    color: (0, 0, 0, 1)
                    size_hint_y: None
                    height: self.texture_size[1]

                MDLabel:
                    text: str(root.result_value)
                    halign: "center"
                    font_style: "Display"
                    role: "large"
                    theme_text_color: "Custom"
                    text_color: "green"
                    font_size: 52

                Label:
                    text: 'ระดับแอลกอฮอล์ในลมหายใจ\nBlood Alcohol Content (BAC)'
                    halign: "center"
                    font_name: "Sarabun"
                    font_size: 36
                    color: (0, 0, 0, .6)
                    size_hint_y: None
                    height: self.texture_size[1]

            MDButton:
                style: "filled"
                size_hint: 1, None
                height: "100dp"
                pos_hint: {"center_x": .5}
                theme_bg_color: "Custom"
                md_bg_color: get_color_from_hex("#0e6effff")
                on_release:
                    app.root.ids.screen_manager.current = "home"
                    root.manager.transition.direction = "right"

                MDButtonText:
                    text: "เสร็จสิ้น / Done"
                    font_style: "Display"
                    font_name: "Sarabun"
                    font_size: 52
                    pos_hint: {"center_x": .5, "center_y": .5}

            Widget:
                size_hint_y: 1
# radio button is a checkbox with a group
<MyLayout>
    BoxLayout:

        orientation: 'vertical'
        size: root.width, root.height

        Label:
            text:'Select programming languages'
            font_size: 32
        
        GridLayout:
            cols: 2

            Label:
                text:'Java'
                font_size: 20
            CheckBox:
                group: 'lang'
                on_active: root.checkbox_clicked(self, self.active, "Java")
            
            Label:
                text:'Python'
                font_size: 20
            CheckBox:
                group: 'lang'
                on_active: root.checkbox_clicked(self, self.active, "Python")

            Label:
                text:'JavaScript'
                font_size: 20
            CheckBox:
                group: 'lang'
                on_active: root.checkbox_clicked(self, self.active, "JavaScript")

        Label:
            id: output_label
            text:''
            font_size: 32
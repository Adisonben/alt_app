# API Configuration
API_BASE_URL=http://localhost:8000
API_KEY=your-api-key-here

# Kiosk Mode: "normal" | "free" | "both"
# normal = show only Normal Mode card (fingerprint auth required)
# free   = show only Free Mode card (no auth required)
# both   = show both cards (user chooses)
KIOSK_MODE=both

#:import get_color_from_hex kivy.utils.get_color_from_hex

<Breathing>:
    md_bg_color: get_color_from_hex("#e8fffeff")

    MDBoxLayout:
        orientation: "horizontal"
        size: root.width, root.height
        spacing: "0dp"
        padding: "24dp"

        # ── Left Column: Icon + Title + Status ──
        MDBoxLayout:
            orientation: "vertical"
            size_hint_x: .45
            spacing: "20dp"
            padding: [0, 0, "20dp", 0]

            Widget:
                size_hint_y: 1

            MDIconButton:
                id: status_icon
                icon: 'weather-windy'
                style: "filled"
                theme_font_size: "Custom"
                font_size: "100sp"
                radius: [self.height / 2, ]
                size_hint: None, None
                size: "140dp", "140dp"
                pos_hint: {'center_x': .5}
                theme_bg_color: "Custom"
                md_bg_color: "blue"
                theme_icon_color: "Custom"
                icon_color: "white"

            Label:
                text: 'กรุณาเป่าลมหายใจ'
                halign: "center"
                font_name: "Sarabun"
                font_size: 72
                color: (0, 0, 0, 1)
                size_hint_y: None
                height: self.texture_size[1]

            Label:
                text: "Please blow into the device"
                font_name: "Sarabun"
                font_size: 42
                halign: "center"
                color: (0, 0, 0, 0.7)
                size_hint_y: None
                height: self.texture_size[1]

            # ── Dynamic status label ──
            Label:
                id: status_label
                text: "กำลังเชื่อมต่ออุปกรณ์... / Connecting..."
                font_name: "Sarabun"
                font_size: 34
                halign: "center"
                color: 0.2, 0.4, 1, 1
                size_hint_y: None
                height: self.texture_size[1]

            # ── Error box (hidden by default) ──
            MDBoxLayout:
                id: error_box
                orientation: "vertical"
                spacing: "16dp"
                adaptive_height: True
                opacity: 0
                disabled: True

                Label:
                    id: error_label
                    text: ""
                    font_name: "Sarabun"
                    font_size: 34
                    halign: "center"
                    color: 0.9, 0.2, 0.2, 1
                    size_hint_y: None
                    height: self.texture_size[1]

                MDBoxLayout:
                    orientation: "horizontal"
                    spacing: "16dp"
                    size_hint_y: None
                    height: "64dp"

                    MDButton:
                        on_release: root.retry_measurement()
                        size_hint: 1, 1
                        MDButtonText:
                            text: "ลองใหม่ / Retry"
                            font_name: "Sarabun"
                            font_size: "32sp"

                    MDButton:
                        on_release: root.cancel_measurement()
                        size_hint: 1, 1
                        MDButtonText:
                            text: "ยกเลิก / Cancel"
                            font_name: "Sarabun"
                            font_size: "32sp"

            Widget:
                size_hint_y: 1

        # ── Right Column: Instructions Card ──
        MDCard:
            style: "elevated"
            padding: "28dp"
            size_hint_x: .55
            orientation: "vertical"
            spacing: "16dp"

            Widget:
                size_hint_y: 1

            Label:
                text: 'คำแนะนำ / Instructions'
                halign: "center"
                font_name: "Sarabun"
                font_size: 42
                bold: True
                color: (0, 0, 0, 1)
                size_hint_y: None
                height: self.texture_size[1]

            Label:
                text: '1. หยิบหลอดจากช่องเก็บหลอด\n    (Pick up the straw.)'
                halign: "left"
                valign: "top"
                font_name: "Sarabun"
                font_size: 34
                color: (0, 0, 0, 1)
                size_hint_y: None
                text_size: self.width, None
                height: self.texture_size[1]

            Label:
                text: '2. เป่าลมออกอย่างแรงและต่อเนื่อง\n    (Blow hard and continuously)'
                halign: "left"
                valign: "top"
                font_name: "Sarabun"
                font_size: 34
                color: (0, 0, 0, 1)
                size_hint_y: None
                text_size: self.width, None
                height: self.texture_size[1]

            Label:
                text: "3. อย่าหยุดจนกว่าจะได้ยินเสียงสัญญาณ\n    (Don't stop until you hear the beep)"
                halign: "left"
                valign: "top"
                font_name: "Sarabun"
                font_size: 34
                color: (0, 0, 0, 1)
                size_hint_y: None
                text_size: self.width, None
                height: self.texture_size[1]

            Widget:
                size_hint_y: 1
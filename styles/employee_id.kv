#:import get_color_from_hex kivy.utils.get_color_from_hex

<NumpadButton@Button>:
    font_size: "72sp"
    font_name: "Sarabun"
    background_normal: ""
    background_color: 0, 0, 0, 0
    color: get_color_from_hex("#1A237E")
    bold: True
    size_hint: 1, 1
    canvas.before:
        Color:
            rgba: get_color_from_hex("#FFFFFF")
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [16,]
        Color:
            rgba: get_color_from_hex("#BBDEFB")
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, 16
            width: 1.5

<NumpadActionButton@Button>:
    font_size: "60sp"
    font_name: "Sarabun"
    background_normal: ""
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    bold: True
    size_hint: 1, 1

<EmployeeID>:
    md_bg_color: get_color_from_hex("#e8fffeff")

    MDBoxLayout:
        orientation: "vertical"
        size: root.width, root.height

        # ── Main content ──
        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: 1
            spacing: "0dp"
            padding: "24dp"

            # ---------- Left: Title + Input ----------
            MDBoxLayout:
                orientation: "vertical"
                size_hint_x: .45
                spacing: "20dp"
                padding: [0, 0, "20dp", 0]
                pos_hint: {"center_y": .5}

                Widget:
                    size_hint_y: 1

                MDIconButton:
                    icon: "card-account-details-outline"
                    style: "tonal"
                    theme_font_size: "Custom"
                    font_size: "100sp"
                    radius: [20,]
                    size_hint: None, None
                    size: "150dp", "150dp"
                    pos_hint: {"center_x": .5}
                    theme_bg_color: "Custom"
                    md_bg_color: get_color_from_hex("#0e6effff")
                    theme_icon_color: "Custom"
                    icon_color: "white"

                Label:
                    markup: True
                    text: '[b]กรอกรหัสพนักงาน[/b]\n[size=52]Enter Employee ID[/size]'
                    halign: "center"
                    font_name: "Sarabun"
                    font_size: 72
                    color: get_color_from_hex("#1A237E")
                    size_hint_y: None
                    height: self.texture_size[1]

                # ---------- Input Display ----------
                BoxLayout:
                    orientation: "vertical"
                    size_hint: 1, None
                    height: "80dp"
                    padding: ["16dp", "12dp", "16dp", "12dp"]

                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#90CAF9")
                        RoundedRectangle:
                            pos: self.x - 2, self.y - 2
                            size: self.width + 4, self.height + 4
                            radius: [16,]
                        Color:
                            rgba: get_color_from_hex("#ffffff")
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [14,]

                    Label:
                        id: input_display
                        text: ""
                        font_size: "88sp"
                        font_name: "Sarabun"
                        bold: True
                        halign: "center"
                        valign: "middle"
                        text_size: self.size
                        color: get_color_from_hex("#1A237E")

                Widget:
                    size_hint_y: 1

                # ---------- Back button ----------
                MDButton:
                    style: "outlined"
                    size_hint: 1, None
                    height: "56dp"
                    pos_hint: {"center_x": .5}
                    on_release:
                        app.root.ids.screen_manager.current = "home"
                        root.manager.transition.direction = "right"
                    MDButtonText:
                        text: "< Back"
                        font_name: "Sarabun"
                        font_size: "48sp"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex("#1565C0")

                Widget:
                    size_hint_y: 1

            # ---------- Right: Numpad ----------
            MDCard:
                radius: [20,]
                theme_bg_color: "Custom"
                md_bg_color: get_color_from_hex("#E3F2FD")
                elevation: 4
                padding: "16dp"
                spacing: "0dp"
                orientation: "vertical"
                size_hint_x: .55

                GridLayout:
                    cols: 3
                    spacing: "10dp"
                    size_hint: 1, 1

                    # Row 1
                    NumpadButton:
                        text: "1"
                        on_release: root.add_digit("1")
                    NumpadButton:
                        text: "2"
                        on_release: root.add_digit("2")
                    NumpadButton:
                        text: "3"
                        on_release: root.add_digit("3")

                    # Row 2
                    NumpadButton:
                        text: "4"
                        on_release: root.add_digit("4")
                    NumpadButton:
                        text: "5"
                        on_release: root.add_digit("5")
                    NumpadButton:
                        text: "6"
                        on_release: root.add_digit("6")

                    # Row 3
                    NumpadButton:
                        text: "7"
                        on_release: root.add_digit("7")
                    NumpadButton:
                        text: "8"
                        on_release: root.add_digit("8")
                    NumpadButton:
                        text: "9"
                        on_release: root.add_digit("9")

                    # Row 4: Clear - 0 - OK
                    NumpadActionButton:
                        text: "ลบ"
                        on_release: root.clear_digits()
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#EF5350")
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [16,]

                    NumpadButton:
                        text: "0"
                        on_release: root.add_digit("0")

                    NumpadActionButton:
                        text: "OK"
                        on_release: root.submit_id()
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#43A047")
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [16,]

        # ── Step Indicator ──
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: "52dp"
            padding: "16dp", "8dp"
            spacing: "8dp"

            canvas.before:
                Color:
                    rgba: 0.93, 0.93, 0.93, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "1. เลือกโหมด"
                font_name: "Sarabun"
                font_size: "26sp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"
            Label:
                text: ">"
                font_size: "26sp"
                size_hint_x: None
                width: "24dp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"
            Label:
                text: "2. กรอก ID"
                font_name: "Sarabun"
                font_size: "26sp"
                bold: True
                color: get_color_from_hex("#0e6eff")
                halign: "center"
            Label:
                text: ">"
                font_size: "26sp"
                size_hint_x: None
                width: "24dp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"
            Label:
                text: "3. วัดผล"
                font_name: "Sarabun"
                font_size: "26sp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"
            Label:
                text: ">"
                font_size: "26sp"
                size_hint_x: None
                width: "24dp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"
            Label:
                text: "4. ผลลัพธ์"
                font_name: "Sarabun"
                font_size: "26sp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"

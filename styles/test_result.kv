#:import get_color_from_hex kivy.utils.get_color_from_hex

<TestResult>:
    md_bg_color: get_color_from_hex("#e8fffeff")
    # on_kv_post: root.start_timer()

    FloatLayout:
        orientation: "vertical"
        size: root.width, root.height
        
        MDBoxLayout:
            orientation: "vertical"
            #md_bg_color: get_color_from_hex("#b1b1b1ff")
            pos_hint: {"center_x": .5, "center_y": .45}
            size_hint_y: None
            height: 280
            spacing: 10

            MDBoxLayout:
                orientation: "vertical"
                padding: 0,0,0,30
                spacing: 30
                adaptive_height: True
                
                MDIconButton:
                    icon: 'checkbox-marked-circle-outline'
                    style: "filled"
                    theme_font_size: "Custom"
                    font_size: "80sp"
                    radius: [self.height / 2, ]
                    size_hint: None, None
                    size: "150dp", "150dp"
                    pos_hint: {'center_x': .5}
                    theme_bg_color: "Custom"
                    md_bg_color: get_color_from_hex("#d4fdd6ff")
                    theme_icon_color: "Custom"
                    icon_color: get_color_from_hex("#008000ff")
                # Image:
                #     source: "assets/fingerprint.png"
                #     size_hint: None, None
                #     size: 100, 100
                #     pos_hint: {"center_x": .5}


            MDBoxLayout:
                orientation: "vertical"
                spacing: 30
                adaptive_height: True

                # Label:
                #     markup: True
                #     text: 'ปลอดภัย'
                #     halign: "center"
                #     font_name: "Sarabun"
                #     font_size: 50
                #     color: (0,0,0,1)

                # MDLabel:
                #     text: "Safe"
                #     font_style: "Title"
                #     font_name: "Sarabun"
                #     adaptive_height: True
                #     font_size: 32
                #     halign: "center"
                
                MDCard:
                    style: "elevated"
                    padding: 20
                    spacing: '20dp'
                    size_hint: None, None
                    size: "500dp", "400dp"
                    pos_hint: {'center_x': .5}
                    orientation: "vertical"

                    Label:
                        text: 'ผลการตรวจ | Test Result'
                        halign: "center"
                        font_name: "Sarabun"
                        font_size: 40
                        color: (0,0,0,1)

                    MDLabel:
                        text: "0.00 %"
                        halign: "center"
                        font_style: "Display"
                        role: "large"
                        theme_text_color: "Custom"
                        text_color: "green"
                        padding: ('0dp', '50dp', '0dp', '10dp')

                    MDBoxLayout:
                        orientation: "vertical"
                                 

                        Label:
                            text: 'ระดับแอลกอฮอล์ในลมหายใจ'
                            halign: "center"
                            font_name: "Sarabun"
                            font_size: 30
                            color: (0,0,0,.6)
                        Label:
                            text: 'Blood Alcohol Content (BAC)'
                            halign: "center"
                            font_name: "Sarabun"
                            font_size: 30
                            color: (0,0,0,.6)
                        
                    MDCard:
                        style: "elevated"
                        padding: 10
                        size_hint: None, None
                        size: "400dp", "100dp"
                        pos_hint: {'center_x': .5}
                        orientation: "vertical"
                        theme_bg_color: "Custom"
                        md_bg_color: get_color_from_hex("#c0ffc3ff")

                        Label:
                            text: 'ผลการตรวจไม่พบแอลกอฮอล์เกินขีดจำกัด'
                            halign: "center"
                            font_name: "Sarabun"
                            font_size: 25
                            color: (0,0,0,.6)
                        Label:
                            text: 'No alcohol detected above legal limit'
                            halign: "center"
                            font_name: "Sarabun"
                            font_size: 25
                            color: (0,0,0,.6)

        MDButton:
            style: "filled"
            pos_hint: {"center_x": .5}
            theme_bg_color: "Custom"
            md_bg_color: get_color_from_hex("#01e1ffff")
            on_release: 
                app.root.ids.screen_manager.current = "home"
                root.manager.transition.direction = "left"
            MDButtonText:
                text: "Next"
                pos_hint: {"center_x": .5, "center_y": .5}            
            
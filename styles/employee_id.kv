#:import get_color_from_hex kivy.utils.get_color_from_hex

<NumpadButton@Button>:
    font_size: "28sp"
    font_name: "Sarabun"
    background_normal: ""
    background_color: 0, 0, 0, 0
    color: get_color_from_hex("#1A237E")
    bold: True
    size_hint: 1, 1
    canvas.before:
        Color:
            rgba: get_color_from_hex("#FFFFFF")
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [12,]
        Color:
            rgba: get_color_from_hex("#BBDEFB")
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, 12
            width: 1.2

<NumpadActionButton@Button>:
    font_size: "20sp"
    font_name: "Sarabun"
    background_normal: ""
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    bold: True
    size_hint: 1, 1

<EmployeeID>:
    md_bg_color: get_color_from_hex("#e8fffeff")

    FloatLayout:
        size: root.width, root.height

        MDCard:
            radius: [20,]
            theme_bg_color: "Custom"
            md_bg_color: get_color_from_hex("#E3F2FD")
            elevation: 4
            padding: "20dp"
            spacing: "12dp"
            orientation: "vertical"
            size_hint: None, None
            size: "440dp", "580dp"
            pos_hint: {"center_x": .5, "center_y": .5}

            # ---------- Title Section ----------
            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                spacing: "4dp"
                padding: [0, 0, 0, "4dp"]

                MDIconButton:
                    icon: "card-account-details-outline"
                    style: "tonal"
                    theme_font_size: "Custom"
                    font_size: "48sp"
                    radius: [16,]
                    size_hint: None, None
                    size: "80dp", "80dp"
                    pos_hint: {"center_x": .5}
                    theme_bg_color: "Custom"
                    md_bg_color: get_color_from_hex("#0e6effff")
                    theme_icon_color: "Custom"
                    icon_color: "white"

                Label:
                    markup: True
                    text: '[b]กรอกรหัสพนักงาน[/b]\n[size=20]Enter Employee ID[/size]'
                    halign: "center"
                    font_name: "Sarabun"
                    font_size: 32
                    color: get_color_from_hex("#1A237E")
                    size_hint_y: None
                    height: self.texture_size[1]

            # ---------- Input Display ----------
            BoxLayout:
                orientation: "vertical"
                size_hint: 1, None
                height: "56dp"
                padding: ["16dp", "8dp", "16dp", "8dp"]

                canvas.before:
                    Color:
                        rgba: get_color_from_hex("#90CAF9")
                    RoundedRectangle:
                        pos: self.x - 2, self.y - 2
                        size: self.width + 4, self.height + 4
                        radius: [14,]
                    Color:
                        rgba: get_color_from_hex("#ffffff")
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [12,]

                Label:
                    id: input_display
                    text: ""
                    font_size: "32sp"
                    font_name: "Sarabun"
                    bold: True
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    color: get_color_from_hex("#1A237E")

            # ---------- Numpad ----------
            GridLayout:
                cols: 3
                spacing: "8dp"
                size_hint: 1, 1

                # Row 1
                NumpadButton:
                    text: "1"
                    on_release: root.add_digit("1")
                NumpadButton:
                    text: "2"
                    on_release: root.add_digit("2")
                NumpadButton:
                    text: "3"
                    on_release: root.add_digit("3")

                # Row 2
                NumpadButton:
                    text: "4"
                    on_release: root.add_digit("4")
                NumpadButton:
                    text: "5"
                    on_release: root.add_digit("5")
                NumpadButton:
                    text: "6"
                    on_release: root.add_digit("6")

                # Row 3
                NumpadButton:
                    text: "7"
                    on_release: root.add_digit("7")
                NumpadButton:
                    text: "8"
                    on_release: root.add_digit("8")
                NumpadButton:
                    text: "9"
                    on_release: root.add_digit("9")

                # Row 4: Clear - 0 - OK
                NumpadActionButton:
                    text: "Clear"
                    on_release: root.clear_digits()
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#EF5350")
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [12,]

                NumpadButton:
                    text: "0"
                    on_release: root.add_digit("0")

                NumpadActionButton:
                    text: "OK"
                    font_size: "24sp"
                    on_release: root.submit_id()
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#43A047")
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [12,]

            # ---------- Back button ----------
            MDButton:
                style: "text"
                pos_hint: {"center_x": .5}
                size_hint_y: None
                height: "36dp"
                on_release:
                    app.root.ids.screen_manager.current = "home"
                    root.manager.transition.direction = "right"
                MDButtonText:
                    text: "< Back"
                    font_name: "Sarabun"
                    font_size: "16sp"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex("#1565C0")

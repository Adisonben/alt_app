#:import utils kivy.utils

<Button>
    font_size: 32
    background_normal: ''
    background_color: utils.get_color_from_hex('#ff58ffff')
    size_hint: .3,.3

<TextInput>
    background_color: utils.get_color_from_hex('#ffffffff')

<Label>
    font_size: 32

<MyGridLayout>
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex('#b0ffffff')
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation:'vertical'
        size: root.width, root.height

        Label:
            id: name_label
            text: "What is your name?"
            font_size: 32

        TextInput:
            id: name_input
            multiline: False
            size_hint: (1, .5)

        Button:
            size_hint: (1, .5)
            font_size: 32
            text: "Submit"
            on_press: root.press()

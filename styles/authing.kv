#:import get_color_from_hex kivy.utils.get_color_from_hex

<Authing>:
    md_bg_color: get_color_from_hex("#e8fffeff")

    FloatLayout:
        size: root.width, root.height

        # ── Fingerprint scan state ──
        MDBoxLayout:
            id: fingerprint_box
            orientation: "vertical"
            opacity: 1
            disabled: False
            pos_hint: {"center_x": .5, "center_y": .5}
            size_hint: None, None
            size: root.width, root.height
            spacing: "20dp"
            padding: "40dp"

            Widget:
                size_hint_y: 1

            Image:
                source: "assets/fingerprint.png"
                size_hint: None, None
                size: 180, 180
                pos_hint: {"center_x": .5}
                on_kv_post: root.start_heartbeat(self)

            Label:
                text: 'กรุณาแสกนลายนิ้วมือ'
                halign: "center"
                font_name: "Sarabun"
                font_size: 72
                color: (0, 0, 0, 1)
                size_hint_y: None
                height: self.texture_size[1]

            MDLabel:
                text: "Please scan your fingerprint"
                font_style: "Title"
                font_name: "Sarabun"
                adaptive_height: True
                font_size: 40
                halign: "center"

            Label:
                text: 'วางนิ้วบนเครื่องสแกนเพื่อตรวจสอบสิทธิ์'
                halign: "center"
                font_name: "Sarabun"
                font_size: 28
                color: (0, 0, 0, .5)
                size_hint_y: None
                height: self.texture_size[1]

            Widget:
                size_hint_y: 1

        # ── Fail state ──
        MDBoxLayout:
            id: result_box_fail
            orientation: "vertical"
            opacity: 0
            disabled: True
            pos_hint: {"center_x": .5, "center_y": .5}
            size_hint: None, None
            size: root.width, root.height
            spacing: "20dp"
            padding: "40dp"

            Widget:
                size_hint_y: 1

            MDButton:
                style: "tonal"
                radius: [self.height / 2, ]
                size_hint: None, None
                size: "120dp", "120dp"
                pos_hint: {"center_x": .5}
                theme_bg_color: "Custom"
                md_bg_color: get_color_from_hex("#ff0000ff")

                MDButtonIcon:
                    icon: "alpha-x-circle"
                    theme_font_size: "Custom"
                    font_size: "120sp"
                    theme_icon_color: "Custom"
                    icon_color: "white"
                    pos_hint: {"center_x": .5, "center_y": .5}

            Label:
                text: 'ไม่สามารถตรวจสอบได้'
                halign: "center"
                font_name: "Sarabun"
                font_size: 72
                color: (0, 0, 0, 1)
                size_hint_y: None
                height: self.texture_size[1]

            MDLabel:
                text: "Authentication failed"
                font_style: "Title"
                font_name: "Sarabun"
                adaptive_height: True
                font_size: 40
                halign: "center"

            Label:
                text: 'กรุณาแสกนลายนิ้วมือใหม่อีกครั้ง'
                halign: "center"
                font_name: "Sarabun"
                font_size: 28
                color: (0, 0, 0, .5)
                size_hint_y: None
                height: self.texture_size[1]

            Widget:
                size_hint_y: 1

        # ── Pass state ──
        MDBoxLayout:
            id: result_box_pass
            orientation: "vertical"
            opacity: 0
            disabled: True
            pos_hint: {"center_x": .5, "center_y": .5}
            size_hint: None, None
            size: root.width, root.height
            spacing: "20dp"
            padding: "40dp"

            Widget:
                size_hint_y: 1

            MDButton:
                style: "tonal"
                radius: [self.height / 2, ]
                size_hint: None, None
                size: "120dp", "120dp"
                pos_hint: {"center_x": .5}
                theme_bg_color: "Custom"
                md_bg_color: get_color_from_hex("#09ff00ff")

                MDButtonIcon:
                    icon: "check-circle"
                    theme_font_size: "Custom"
                    font_size: "120sp"
                    theme_icon_color: "Custom"
                    icon_color: "white"
                    pos_hint: {"center_x": .5, "center_y": .5}

            Label:
                text: 'ยืนยันตัวตนสำเร็จ'
                halign: "center"
                font_name: "Sarabun"
                font_size: 72
                color: (0, 0, 0, 1)
                size_hint_y: None
                height: self.texture_size[1]

            MDLabel:
                text: "Authentication successful"
                font_style: "Title"
                font_name: "Sarabun"
                adaptive_height: True
                font_size: 40
                halign: "center"

            Widget:
                size_hint_y: 1
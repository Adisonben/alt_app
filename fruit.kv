#: set PRIMARY_COLOR (0.85, 0.25, 0.25, 1)
#: set SECONDARY_COLOR (0.1, 0.5, 0.1, 1)

<RootGameScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        
        #พื้นหลัง
        canvas.before:
            Color:
                rgba: 1.0, 0.90, 0.90, 1
            Rectangle:
                source: 'images/bg7.png'
                pos: self.pos
                size: self.size

        #คะแนน (Score Bar)
        MDBoxLayout:
            size_hint_y: 0.1
            padding: "10dp"
            spacing: "10dp"
            
            MDLabel:
                text: "คำถาม : " + str(int(root.current_word_index) + 1)
                font_size: 45
                font_name: 'THSarabunNewBold'
                background_color: (182/255, 66/255, 245/255, 1)
                

                # Text Properties
                color:(0,0,0,1)
                bold: True
                italic: True
                outline_color: (1, 1, 1, 1)
                outline_width: 5
                

            MDCard:
                size_hint_x: None
                width: "200dp"
                radius: [20]
                md_bg_color: 1, 0.5, 0.5, 1  # สีส้มสดใส
                elevation: 12
                
                BoxLayout:
                    orientation: "vertical"
                    padding: "10dp"
                    spacing: "5dp"
                    
                    BoxLayout:
                        orientation: "horizontal"
                        spacing: "5dp"
                        halign: "center"
                        valign: "center"
                        
                        MDIcon:
                            icon: "star"
                            theme_text_color: "Custom"
                            text_color: 1,1,0,1
                            font_size: "30sp"
                        
                        MDLabel:
                            id: score_label
                            text: "0"
                            halign: "center"
                            font_size: "36sp"
                            font_name: "THSarabunNewBold"
                            color: 1,1,1,1
                            bold: True
                        
                        MDIcon:
                            icon: "star"
                            theme_text_color: "Custom"
                            text_color: 1,1,0,1
                            font_size: "30sp"
                    
                    MDProgressBar:
                        id: score_bar
                        value: 0
                        max: 100
                        color: 1,1,0,1
                        height: "12dp"
                        radius: [6,6,6,6]

        # พื้นที่หลัก (Main Content)
        MDBoxLayout:
            size_hint_y: 0.75 
            padding: ["60dp", "20dp", "60dp", "30dp"]
            spacing: "20dp"
            orientation: 'horizontal'
            
            # ส่วนซ้าย: รูปภาพ
            MDCard:
                size_hint_x: 0.45
                radius: [25]
                padding: "8dp"
                md_bg_color: PRIMARY_COLOR
                MDCard:
                    radius: [20]
                    padding: "5dp"
                    md_bg_color: 1, 1, 1, 1 
                    MDBoxLayout:
                        padding: [15, 15, 15, 15]
                        Image:
                            source: root.image_source 
                            fit_mode: "contain"
                            size_hint: 0.9, 0.9
                            pos_hint: {'center_x': 0.5, 'center_y': 0.5}

            # ส่วนขวา: คำศัพท์
            MDBoxLayout:
                size_hint_x: 0.55
                orientation: 'vertical'
                spacing: "20dp"
                padding: "10dp"
                
                MDCard:
                    size_hint_y: 0.35
                    radius: [40]
                    padding: "8dp"
                    md_bg_color: PRIMARY_COLOR
                    MDCard:
                        radius: [30] 
                        padding: "15dp" 
                        md_bg_color: 1, 1, 1, 1 
                        MDBoxLayout:
                            padding: [15, 10, 15, 10]
                            MDLabel:
                                text: root.word_en
                                halign: 'center'
                                valign: 'center'
                                font_style: 'H3'
                                color: 0, 0, 0, 1
                                font_name: 'font/simhei.ttf'

                MDCard:
                    size_hint_y: 0.65
                    radius: [40]
                    padding: "8dp"
                    md_bg_color: PRIMARY_COLOR
                    MDCard:
                        radius: [30]
                        padding: "15dp"
                        md_bg_color: 1, 1, 1, 1
                        MDBoxLayout:
                            orientation: 'vertical'
                            padding: [15, 10, 15, 10]
                            MDLabel:
                                text: root.word_cn
                                halign: 'center'
                                valign: 'center'
                                size_hint_y: 0.6
                                font_style: 'H2'
                                color: 0, 0, 0, 1 
                                font_name: 'font/simhei.ttf'

                            MDLabel:
                                text: root.word_pinyin
                                halign: 'center'
                                valign: 'center'
                                size_hint_y: 0.4
                                font_style: 'H5'
                                color: 0, 0, 0, 1
                                font_name: 'font/simhei.ttf'
                            
        MDBoxLayout:
            size_hint_y: 0.15 
            orientation: 'vertical'
            padding: ["10dp", "5dp", "10dp", "10dp"]
            spacing: "0dp"
            
            # Row สำหรับ Timer Text และ ปุ่ม Next
            MDBoxLayout:
                size_hint_y: None
                height: "40dp"
                padding: "0dp"
                
                MDLabel:
                    id: timer_label
                    text: root.countdown_display
                    halign: 'left' 
                    font_style: 'H6'
                    color: 0.3, 0.3, 0.3, 1
                    size_hint_x: 0.5


                MDRaisedButton:
                    text: "ถัดไป"
                    on_release: root.go_to_next_word(self)
                    md_bg_color: PRIMARY_COLOR
                    adaptive_width: True
                    pos_hint: {"right": 1} 
                    font_style: 'H6'
                    font_name: 'THSarabunNewBold'  


            # ส่วนนี้คือส่วนที่เคยเป็น MDProgressBar ถูกลบออกไป
            # และนำ FloatLayout ที่มี Image (ผลไม้) มาใส่ตรงนี้แทน
            FloatLayout:
                size_hint_y: None
                height: "60dp" # กำหนดความสูงเพื่อให้ Image มีพื้นที่แสดงผล
            
                # Image (ผลไม้) 
                Image:
                    id: animated_fruit_image
                    source: root.image_source
                    source: 'images/22.png'
                    size_hint: None, None
                    size: 80, 80  
                    keep_ratio: True
                    pos_hint: {'center_x': root.image_x_pos, 'center_y': 0.5}

            BoxLayout:
                id: main_game_layout
                canvas.before:
                    Color:
                        rgba: 1,1,1,0 if root.game_over else 1,1,1,1
                    Rectangle:
                        source: "bg7.png"
                        size: self.size
                        pos: self.pos







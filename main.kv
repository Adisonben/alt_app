MDScreen:
    Idle:
        id: idle_overlay
        size_hint: 1, 1
        pos_hint: {"x": 0, "y": 0}

    MDBoxLayout:
        orientation: "vertical"

        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: 72
            padding: 16, 8, 16, 8
            spacing: 8

            canvas.before:
                Color:
                    rgba: 0.055, 0.416, 1, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            BoxLayout:
                orientation: "vertical"
                size_hint_x: 0.3

                Label:
                    text: "IP Address"
                    font_name: "Sarabun"
                    font_size: "22sp"
                    color: 1, 1, 1, 0.7
                    halign: "left"
                    text_size: self.size
                    valign: "middle"
                Label:
                    id: ip_label
                    text: "192.168.1.0"
                    font_name: "Sarabun"
                    font_size: "26sp"
                    color: 0.6, 1, 0.6, 1
                    halign: "left"
                    text_size: self.size
                    valign: "middle"

            Label:
                text: "ALT Iddrives"
                halign: "center"
                font_name: "Sarabun"
                font_size: "36sp"
                bold: True
                color: 1, 1, 1, 1
                size_hint_x: 0.4

            BoxLayout:
                orientation: "vertical"
                size_hint_x: 0.3

                Label:
                    id: clock_label
                    text: "00:00:00"
                    font_name: "Sarabun"
                    font_size: "32sp"
                    color: 1, 1, 1, 1
                    halign: "right"
                    text_size: self.size
                    valign: "middle"
                Label:
                    id: date_label
                    text: ""
                    font_name: "Sarabun"
                    font_size: "22sp"
                    color: 1, 1, 1, 0.7
                    halign: "right"
                    text_size: self.size
                    valign: "middle"

        MDScreenManager:
            # md_bg_color: app.theme_cls.primaryColor
            id: screen_manager

            # PrepareResult:
            #     name: "prepareresult"
            Home:
                name: "home"
            EmployeeID:
                name: "employeeid"
            Authing:
                name: "authing"
            Breathing:
                name: "breathing"
            TestResult:
                name: "testresult"
            ShowError:
                name: "showerror"
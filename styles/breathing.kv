#:import get_color_from_hex kivy.utils.get_color_from_hex

<Breathing>:
    md_bg_color: get_color_from_hex("#e8fffeff")
    # on_kv_post: root.start_timer()

    MDBoxLayout:
        orientation: "horizontal"
        spacing: "20dp"
        padding: "20dp"
        
        # Left Column: Camera Preview with Border
        MDBoxLayout:
            orientation: "vertical"
            size_hint_x: .5
            spacing: "10dp"

            Label:
                text: "Camera Preview"
                halign: "center"
                font_name: "Sarabun"
                font_size: "24sp"
                color: (0,0,0,1)
                size_hint_y: None
                height: "40dp"

            MDCard:
                size_hint_y: .5
                style: "outlined"
                line_color: 0, 0, 0, 1
                line_width: 2
                padding: "5dp"
                
                FloatLayout:
                    size_hint: 1, 1
                    
                    Image:
                        id: camera_image
                        size_hint: 1, 1
                        pos: self.parent.pos
                        size: self.parent.size
                        allow_stretch: True
                        keep_ratio: False
                    
                    MDLabel:
                        id: camera_status
                        text: "Camera not available"
                        halign: "center"
                        valign: "center"
                        theme_text_color: "Hint"
                        size_hint: 1, 1

        # Right Column: Instructions
        MDBoxLayout:
            orientation: "vertical"
            size_hint_x: .5
            spacing: "10dp"
            pos_hint: {"center_y": .5}
            adaptive_height: True

            MDIconButton:
                icon: 'weather-windy'
                style: "filled"
                theme_font_size: "Custom"
                font_size: "40sp"
                radius: [self.height / 2, ]
                size_hint: None, None
                size: "70dp", "70dp"
                pos_hint: {'center_x': .5}
                theme_bg_color: "Custom"
                md_bg_color: "blue"
                theme_icon_color: "Custom"
                icon_color: "white"

            Label:
                markup: True
                text: 'กรุณาเป่าลมหายใจ '
                halign: "center"
                font_name: "Sarabun"
                font_size: "30sp"
                color: (0,0,0,1)
                size_hint_y: None
                height: self.texture_size[1]

            MDLabel:
                text: "Please blow into the device"
                font_style: "Title"
                font_name: "Sarabun"
                adaptive_height: True
                font_size: "20sp"
                halign: "center"
            
            MDCard:
                style: "elevated"
                padding: "10dp"
                size_hint: 1, None
                height: "180dp"
                orientation: "vertical"

                Label:
                    text: 'คำแนะนำ Instructions'
                    halign: "center"
                    font_style: "Headline"
                    font_name: "Sarabun"
                    font_size: "18sp"
                    color: (0,0,0,1)
                    size_hint_y: None
                    height: "30dp"

                Label:
                    text: '1. หยิบหลอดจากช่องเก็บหลอด (Pick up the straw.)'
                    halign: "left"
                    valign: "middle"
                    font_name: "Sarabun"
                    size_hint_x: 1
                    font_size: "16sp"
                    color: (0,0,0,1)
                    text_size: self.width, None

                Label:
                    text: '2. เป่าลมออกอย่างแรงและต่อเนื่อง (Blow hard and continuously)'
                    halign: "left"
                    valign: "middle"
                    font_name: "Sarabun"
                    size_hint_x: 1
                    font_size: "16sp"
                    color: (0,0,0,1)
                    text_size: self.width, None

                Label:
                    text: "3. อย่าหยุดจนกว่าจะได้ยินเสียงสัญญาณ (Don't stop until you hear the beep)"
                    halign: "left"
                    valign: "middle"
                    font_name: "Sarabun"
                    size_hint_x: 1
                    font_size: "16sp"
                    color: (0,0,0,1)
                    text_size: self.width, None

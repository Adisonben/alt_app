#:import get_color_from_hex kivy.utils.get_color_from_hex

<Authing>:
    md_bg_color: get_color_from_hex("#e8fffeff")

    MDBoxLayout:
        orientation: "vertical"
        size: root.width, root.height

        # ── Main content ──
        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: 1
            spacing: "0dp"
            padding: "24dp"

            # ── Left Column: Fingerprint icon + title (always visible) ──
            MDBoxLayout:
                orientation: "vertical"
                size_hint_x: .45
                spacing: "20dp"
                padding: [0, 0, "20dp", 0]

                Widget:
                    size_hint_y: 1

                Image:
                    source: "assets/fingerprint.png"
                    size_hint: None, None
                    size: 180, 180
                    pos_hint: {"center_x": .5}
                    on_kv_post: root.start_heartbeat(self)

                Label:
                    text: 'กรุณาแสกนลายนิ้วมือ'
                    halign: "center"
                    font_name: "Sarabun"
                    font_size: 96
                    color: (0, 0, 0, 1)
                    size_hint_y: None
                    height: self.texture_size[1]

                Label:
                    text: "Please scan your fingerprint"
                    halign: "center"
                    font_name: "Sarabun"
                    font_size: 56
                    color: (0, 0, 0, 0.7)
                    size_hint_y: None
                    height: self.texture_size[1]

                Label:
                    text: 'วางนิ้วบนเครื่องสแกนเพื่อตรวจสอบสิทธิ์'
                    halign: "center"
                    font_name: "Sarabun"
                    font_size: 48
                    color: (0, 0, 0, .5)
                    size_hint_y: None
                    height: self.texture_size[1]

                Widget:
                    size_hint_y: 1

            # ── Right Column: State panels (scan / fail / pass) ──
            MDCard:
                style: "elevated"
                padding: "28dp"
                size_hint_x: .55
                orientation: "vertical"
                spacing: "0dp"

                # ── Scanning state ──
                MDBoxLayout:
                    id: fingerprint_box
                    orientation: "vertical"
                    opacity: 1
                    disabled: False
                    spacing: "20dp"

                    Widget:
                        size_hint_y: 1

                    MDIconButton:
                        icon: "fingerprint"
                        style: "tonal"
                        theme_font_size: "Custom"
                        font_size: "120sp"
                        radius: [20,]
                        size_hint: None, None
                        size: "160dp", "160dp"
                        pos_hint: {"center_x": .5}
                        theme_bg_color: "Custom"
                        md_bg_color: get_color_from_hex("#0e6effff")
                        theme_icon_color: "Custom"
                        icon_color: "white"

                    Label:
                        text: 'รอการสแกน...'
                        halign: "center"
                        font_name: "Sarabun"
                        font_size: 80
                        color: (0, 0, 0, 1)
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        text: "Waiting for scan..."
                        halign: "center"
                        font_name: "Sarabun"
                        font_size: 52
                        color: (0, 0, 0, 0.6)
                        size_hint_y: None
                        height: self.texture_size[1]

                    Widget:
                        size_hint_y: 1

                # ── Fail state ──
                MDBoxLayout:
                    id: result_box_fail
                    orientation: "vertical"
                    opacity: 0
                    disabled: True
                    spacing: "20dp"

                    Widget:
                        size_hint_y: 1

                    MDButton:
                        style: "tonal"
                        radius: [self.height / 2, ]
                        size_hint: None, None
                        size: "120dp", "120dp"
                        pos_hint: {"center_x": .5}
                        theme_bg_color: "Custom"
                        md_bg_color: get_color_from_hex("#ff0000ff")

                        MDButtonIcon:
                            icon: "alpha-x-circle"
                            theme_font_size: "Custom"
                            font_size: "120sp"
                            theme_icon_color: "Custom"
                            icon_color: "white"
                            pos_hint: {"center_x": .5, "center_y": .5}

                    Label:
                        text: 'ไม่สามารถตรวจสอบได้'
                        halign: "center"
                        font_name: "Sarabun"
                        font_size: 96
                        color: (0, 0, 0, 1)
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        text: "Authentication failed"
                        halign: "center"
                        font_name: "Sarabun"
                        font_size: 56
                        color: (0, 0, 0, 0.7)
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        text: 'กรุณาแสกนลายนิ้วมือใหม่อีกครั้ง'
                        halign: "center"
                        font_name: "Sarabun"
                        font_size: 48
                        color: (0, 0, 0, .5)
                        size_hint_y: None
                        height: self.texture_size[1]

                    Widget:
                        size_hint_y: 1

                # ── Pass state ──
                MDBoxLayout:
                    id: result_box_pass
                    orientation: "vertical"
                    opacity: 0
                    disabled: True
                    spacing: "20dp"

                    Widget:
                        size_hint_y: 1

                    MDButton:
                        style: "tonal"
                        radius: [self.height / 2, ]
                        size_hint: None, None
                        size: "120dp", "120dp"
                        pos_hint: {"center_x": .5}
                        theme_bg_color: "Custom"
                        md_bg_color: get_color_from_hex("#09ff00ff")

                        MDButtonIcon:
                            icon: "check-circle"
                            theme_font_size: "Custom"
                            font_size: "120sp"
                            theme_icon_color: "Custom"
                            icon_color: "white"
                            pos_hint: {"center_x": .5, "center_y": .5}

                    Label:
                        text: 'ยืนยันตัวตนสำเร็จ'
                        halign: "center"
                        font_name: "Sarabun"
                        font_size: 96
                        color: (0, 0, 0, 1)
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        text: "Authentication successful"
                        halign: "center"
                        font_name: "Sarabun"
                        font_size: 56
                        color: (0, 0, 0, 0.7)
                        size_hint_y: None
                        height: self.texture_size[1]

                    Widget:
                        size_hint_y: 1

                # ── Device error state ──
                MDBoxLayout:
                    id: device_error_box
                    orientation: "vertical"
                    opacity: 0
                    disabled: True
                    spacing: "20dp"

                    Widget:
                        size_hint_y: 1

                    MDButton:
                        style: "tonal"
                        radius: [self.height / 2, ]
                        size_hint: None, None
                        size: "120dp", "120dp"
                        pos_hint: {"center_x": .5}
                        theme_bg_color: "Custom"
                        md_bg_color: get_color_from_hex("#FF9800")

                        MDButtonIcon:
                            icon: "alert-circle-outline"
                            theme_font_size: "Custom"
                            font_size: "120sp"
                            theme_icon_color: "Custom"
                            icon_color: "white"
                            pos_hint: {"center_x": .5, "center_y": .5}

                    Label:
                        id: device_error_label
                        text: "ไม่พบเครื่องสแกนลายนิ้วมือ\nFingerprint scanner not found"
                        halign: "center"
                        font_name: "Sarabun"
                        font_size: 72
                        color: (0.8, 0.3, 0, 1)
                        size_hint_y: None
                        height: self.texture_size[1]

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing: "16dp"
                        size_hint_y: None
                        height: "72dp"
                        padding: ["8dp", 0]

                        MDButton:
                            style: "filled"
                            size_hint: 1, 1
                            theme_bg_color: "Custom"
                            md_bg_color: get_color_from_hex("#0e6effff")
                            on_release: root.retry_device()
                            MDButtonText:
                                text: "Retry"
                                font_name: "Sarabun"
                                font_size: "48sp"

                        MDButton:
                            style: "outlined"
                            size_hint: 1, 1
                            on_release: root.go_home_from_error()
                            MDButtonText:
                                text: "Home"
                                font_name: "Sarabun"
                                font_size: "48sp"

                    Widget:
                        size_hint_y: 1

        # ── Step Indicator ──
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: "52dp"
            padding: "16dp", "8dp"
            spacing: "8dp"

            canvas.before:
                Color:
                    rgba: 0.93, 0.93, 0.93, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "1. เลือกโหมด"
                font_name: "Sarabun"
                font_size: "26sp"
                bold: True
                color: get_color_from_hex("#0e6eff")
                halign: "center"
            Label:
                text: ">"
                font_size: "26sp"
                size_hint_x: None
                width: "24dp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"
            Label:
                text: "2. กรอก ID"
                font_name: "Sarabun"
                font_size: "26sp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"
            Label:
                text: ">"
                font_size: "26sp"
                size_hint_x: None
                width: "24dp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"
            Label:
                text: "3. วัดผล"
                font_name: "Sarabun"
                font_size: "26sp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"
            Label:
                text: ">"
                font_size: "26sp"
                size_hint_x: None
                width: "24dp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"
            Label:
                text: "4. ผลลัพธ์"
                font_name: "Sarabun"
                font_size: "26sp"
                color: 0.6, 0.6, 0.6, 1
                halign: "center"